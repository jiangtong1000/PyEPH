&CONTROL
  prefix = 'PREFIX'                         ! TODO: same prefix
  calculation = 'nscf'
  wf_collect = .true.
  outdir='./tmp'
  pseudo_dir='TODO_PSEUDO_DIR'
/
&SYSTEM
   ntyp             = 3                     ! TODO: number of atom types
   nat              = 72                    ! TODO: number of atoms
   nbnd             = 120                   ! TODO: nocc + extra bands (enough to cover Wannier window)
   ibrav            = 0
   ecutwfc          = 90.0                  ! TODO: same cutoffs as SCF
   ecutrho          = 360.0
   vdw_corr = 'grimme-d3'                  ! TODO: same as SCF
   input_dft = 'PBE'
   dftd3_threebody = .false.
/
&ELECTRONS
  conv_thr = 1.0d-15
  mixing_mode = 'plain'
  mixing_beta = 0.7
  diagonalization = 'david'
  diago_full_acc = .true.
/
ATOMIC_SPECIES
! TODO: same species as SCF
S 32.06 S_NCSR.upf
C 12.011 C_NCSR.upf
H 1.008 H_NCSR.upf

CELL_PARAMETERS angstrom
! TODO: same relaxed cell parameters as 1_SCF

ATOMIC_POSITIONS angstrom
! TODO: same relaxed atomic positions as 1_SCF

! K_POINTS: explicit uniform grid in crystal coords, NO symmetry reduction.
! Generate with:  wannier90/utility/kmesh.pl nk1 nk2 nk3
! Below is a 4x4x4 example (64 k-points, equal weights = 1/64):
