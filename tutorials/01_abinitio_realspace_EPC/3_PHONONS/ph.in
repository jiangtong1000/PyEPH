&inputph
  verbosity='debug'
  tr2_ph=1.0d-17                           ! TODO: this has to be this tight
  prefix='PREFIX'                           ! TODO: same prefix as SCF
  asr=.true.
  ldisp=.true.
  epsil=.true.
  lqdir=.true.
  outdir='./tmp'
  dftd3_hess='PREFIX.hess'                  ! TODO: remove if no D3; symlink from 2_D3HESS/
  fildyn  = 'PREFIX.dyn.xml'                ! TODO: replace PREFIX
  fildvscf = 'dvscf'
  nq1=2, nq2=2, nq3=2                      ! TODO: q-point grid
/
