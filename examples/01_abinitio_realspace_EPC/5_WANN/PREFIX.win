begin projections
 random                                     ! TODO: set projections (random works for many cases)
end projections
guiding_centres=true

num_bands = 120                             ! TODO: must match nbnd in nscf.in
num_wann = 2                                ! TODO: number of Wannier functions

iprint = 2
dis_num_iter =  500
dis_win_min = 1.35                          ! TODO: check the FOMO (Fermi-Orbital MO) in nscf.out
dis_win_max = 2.0                           ! TODO: disentanglement energy window (eV)
dis_froz_min = 1.35                         ! TODO: frozen window min (eV)
dis_froz_max = 2.0                          ! TODO: frozen window max (eV)
num_iter  =   10000
mp_grid : 4 4 4                             ! TODO: must match k-grid in nscf.in

kmesh_tol = 1e-4                            ! fixes "kmesh_get_bvector: Not enough bvectors found"

begin unit_cell_cart
angstrom
! TODO: same RELAXED cell as 1_SCF

end unit_cell_cart

write_u_matrices = .true.
write_xyz = .true.

#restart = plot
BANDS_PLOT = False

begin atoms_cart
angstrom
! TODO: same RELAXED positions as 1_SCF
! ... paste relaxed atomic positions here ...
end atoms_cart

